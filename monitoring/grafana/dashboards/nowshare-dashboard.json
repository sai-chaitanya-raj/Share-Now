        {
          "datasource": { "type": "prometheus", "uid": "${DS_PROMETHEUS}" },
          "expr": "(sum(rate(flask_http_errors_total{job=\"nowshare-app\"}[5m])) / sum(rate(flask_http_requests_total{job=\"nowshare-app\"}[5m]))) * 100 or vector(0)",
          "legendFormat": "Error Rate %",
          "refId": "A"
        }
      ],
      "title": "🔴 Error Rate",
      "type": "gauge"
